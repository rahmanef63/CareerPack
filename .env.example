# Convex CLI — self-hosted target.
#
# Fill .env.local for local dev. CI should use repository secrets.
# Generate admin key from the self-hosted backend container:
#   docker compose exec backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=https://your-convex-backend.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=your-deployment|REPLACE_WITH_ADMIN_KEY
