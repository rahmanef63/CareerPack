# Convex CLI — self-hosted target (prod di example.convex.cloud)
#
# Isi di .env.local untuk local dev. GitHub Actions pakai secrets.
# Dapatkan admin key dari Dokploy backend console:
#   docker compose exec backend ./generate_admin_key.sh
CONVEX_SELF_HOSTED_URL=https://example.convex.cloud
CONVEX_SELF_HOSTED_ADMIN_KEY=careerpack|REPLACE_WITH_ADMIN_KEY
