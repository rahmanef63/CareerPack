# Target Convex self-hosted untuk CLI (pnpm exec convex deploy --env-file ...)
#
# PROD: isi URL + admin key dari dashboard Dokploy your-deployment-dashboard.example.com.
# Generate admin key: `docker compose exec backend ./generate_admin_key.sh`
#
# File ini ADALAH secret — JANGAN commit. Nama akhir: convex.env
CONVEX_SELF_HOSTED_URL=https://example.convex.cloud
CONVEX_SELF_HOSTED_ADMIN_KEY=careerpack|REPLACE_WITH_ADMIN_KEY
