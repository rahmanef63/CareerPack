# Convex self-hosted target for CLI (pnpm exec convex deploy --env-file ...)
#
# PROD: set URL + admin key from your deployment dashboard.
# Generate admin key: `docker compose exec backend ./generate_admin_key.sh`
#
# This file IS a secret — DO NOT commit. Final filename: convex.env
CONVEX_SELF_HOSTED_URL=https://your-convex-backend.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=your-deployment|REPLACE_WITH_ADMIN_KEY
