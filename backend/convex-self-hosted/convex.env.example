# Convex self-hosted target for CLI (pnpm exec convex deploy --env-file ...)
#
# PROD: set URL + admin key from your deployment dashboard.
# Generate admin key: `docker compose exec backend ./generate_admin_key.sh`
#
# This file IS a secret — DO NOT commit. Final filename: convex.env
CONVEX_SELF_HOSTED_URL=https://your-convex-backend.example.com
CONVEX_SELF_HOSTED_ADMIN_KEY=your-deployment|REPLACE_WITH_ADMIN_KEY

# Convex serves httpActions (the /api/health endpoint, AI proxy webhooks,
# OAuth callbacks) on a SEPARATE port — the "site origin" — distinct
# from the API port (3210). Set both origins explicitly so the backend
# emits absolute URLs that match the public hostnames Dokploy proxies.
#
# Without these, /api/health resolves to localhost in the container and
# external uptime probes hit the API port (3210), get 404, and your
# probe thinks the deploy is down.
#
# In Dokploy, configure TWO domains (or one host with path routing):
#   - api.your-host  → container :3210
#   - site.your-host → container :3211
CONVEX_CLOUD_ORIGIN=https://api.your-convex-backend.example.com
CONVEX_SITE_ORIGIN=https://site.your-convex-backend.example.com

# Comma-separated list of emails that auto-promote to role=admin on
# next login (handled in convex/seed.ts → seedForCurrentUser). The
# value is lowercased + trimmed before matching, so casing in the
# auth user's email doesn't matter. Promotion fires on seed only —
# the user must log in once after this is set.
#
# Set on the running Convex BACKEND container (Dokploy env / docker-
# compose env), not just for the CLI deploy — the seed reads
# `process.env` from inside the backend at runtime.
#
# Example: ADMIN_BOOTSTRAP_EMAILS=owner@example.com,partner@example.com
ADMIN_BOOTSTRAP_EMAILS=

# --- Google OAuth ("Lanjutkan dengan Google") ---
# The Google provider in convex/auth.ts reads these from the BACKEND env.
# If they are unset, signIn("google") fails immediately (no client creds) —
# the login button spins, then errors. These MUST be set on the running
# Convex backend (Dokploy env), not just for the CLI deploy.
#
# Setup:
#   1. Google Cloud Console → APIs & Services → Credentials →
#      Create credentials → OAuth client ID → type "Web application".
#   2. Authorized redirect URI (EXACT — the #1 mistake): the Convex
#      HTTP-Actions (.site) origin + /api/auth/callback/google. That is
#      CONVEX_SITE_ORIGIN above, NOT the frontend and NOT the :3210 API origin:
#        https://site.your-convex-backend.example.com/api/auth/callback/google
#   3. (Optional) Authorized JavaScript origin = your frontend, e.g.
#      https://careerpack.org
#   4. Paste the Client ID + secret below, then REDEPLOY/RESTART the backend.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Frontend URL the OAuth flow redirects back to AFTER Google auth completes.
# This is the public Next.js site — distinct from CONVEX_SITE_ORIGIN above.
# Without it, the post-callback redirect lands on the wrong origin.
#   prod:  https://careerpack.org
#   local: http://localhost:3000
SITE_URL=

# Redact server stack traces from client error payloads in production.
# Without this, ConvexError details / traces can stream to connected clients.
REDACT_LOGS_TO_CLIENT=true
