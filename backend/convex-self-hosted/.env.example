# Convex self-hosted backend image (official).
# PINNED — do NOT use `:latest`. An unpinned image was the root cause of the
# 2026-06-11 incident: `:latest` drifted, got pruned, and re-pull failed during
# a ghcr.io outage, leaving the backend with no runnable image. Bumping this pin
# is a scheduled upgrade decision. See backend/convex-self-hosted/docker-compose.yml
# SECURITY comment + docs/progress/2026-06-11-vps-incident-and-hardening.md.
CONVEX_SELF_HOSTED_IMAGE=ghcr.io/get-convex/convex-backend:db5c4247

# Public URL exposed to the frontend
CONVEX_CLOUD_ORIGIN=http://localhost:3210
CONVEX_SITE_ORIGIN=http://localhost:3210
CONVEX_SITE_URL=http://localhost:3210

# Server settings
CONVEX_PORT=3210

# Required by @convex-dev/auth for signing tokens
# Dev only: replace with your own long random secret
JWT_PRIVATE_KEY=dev_local_jwt_private_key_change_me_please_32_chars_min
